{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://the-pass.dev/schemas/observation_manifest.v2.schema.json",
  "title": "ObservationManifest",
  "type": "object",
  "required": ["schema_version", "id", "created_at", "paper_plan", "source_package", "data_capture", "signals", "simulated_orders", "quality"],
  "properties": {
    "schema_version": { "const": 2 },
    "id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "paper_plan": { "type": "string", "minLength": 1 },
    "source_package": { "type": "string", "minLength": 1 },
    "data_capture": {
      "type": "object",
      "required": ["event_time_field", "receive_time_field", "decision_time_field", "storage_path"],
      "properties": {
        "event_time_field": { "type": "string", "minLength": 1 },
        "receive_time_field": { "type": "string", "minLength": 1 },
        "decision_time_field": { "type": "string", "minLength": 1 },
        "storage_path": { "type": "string", "minLength": 1 }
      }
    },
    "signals": {
      "type": "object",
      "required": ["format", "fields"],
      "properties": {
        "format": { "type": "string", "minLength": 1 },
        "fields": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "simulated_orders": {
      "type": "object",
      "required": ["format", "fields", "cannot_reach_broker"],
      "properties": {
        "format": { "type": "string", "minLength": 1 },
        "fields": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "cannot_reach_broker": { "const": true }
      }
    },
    "quality": {
      "type": "object",
      "required": ["missing_data_policy", "outage_policy", "clock_skew_policy"],
      "properties": {
        "missing_data_policy": { "type": "string", "minLength": 1 },
        "outage_policy": { "type": "string", "minLength": 1 },
        "clock_skew_policy": { "type": "string", "minLength": 1 }
      }
    }
  },
  "additionalProperties": true
}

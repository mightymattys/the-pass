{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://the-pass.dev/schemas/agent_run.schema.json",
  "title": "AgentRunV1",
  "type": "object",
  "required": [
    "schema_version", "run_id", "task_id", "task_fingerprint", "caller_provider",
    "target_provider", "provider", "model_selection", "policy", "role", "mode", "runtime_depth", "limits", "execution",
    "streams", "result", "result_fingerprint", "patch", "status", "issues", "metadata"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "run_id": { "type": "string", "pattern": "^agent_[a-f0-9]{32}$" },
    "task_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$" },
    "task_fingerprint": { "$ref": "#/$defs/sha256" },
    "caller_provider": { "enum": ["codex", "claude"] },
    "target_provider": { "enum": ["codex", "claude"] },
    "provider": {
      "type": "object",
      "required": ["binary", "version"],
      "properties": {
        "binary": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "model_selection": {
      "type": "object",
      "required": [
        "requested_profile", "requested_workload_class", "resolved_workload_class",
        "resolved_profile", "requested_model", "reasoning_effort", "capabilities",
        "rationale", "routing_policy_sha256"
      ],
      "properties": {
        "requested_profile": { "enum": ["auto", "economy", "balanced", "deep"] },
        "requested_workload_class": { "enum": ["auto", "routine", "standard", "complex", "critical"] },
        "resolved_workload_class": { "enum": ["routine", "standard", "complex", "critical"] },
        "resolved_profile": { "enum": ["economy", "balanced", "deep"] },
        "requested_model": { "type": "string", "minLength": 1 },
        "reasoning_effort": { "type": ["string", "null"], "enum": ["low", "medium", "high", "xhigh", null] },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "rationale": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "string", "minLength": 1 }
        },
        "routing_policy_sha256": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "policy": {
      "type": "object",
      "required": ["schema_version", "interface_version", "sha256"],
      "properties": {
        "schema_version": { "const": 1 },
        "interface_version": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "role": { "enum": ["researcher", "implementer", "reviewer"] },
    "mode": { "enum": ["read_only", "worktree_patch"] },
    "runtime_depth": { "type": "integer", "minimum": 0 },
    "limits": {
      "type": "object",
      "required": ["timeout_seconds", "max_output_bytes", "max_budget_usd", "attempts"],
      "properties": {
        "timeout_seconds": { "type": "integer", "minimum": 1 },
        "max_output_bytes": { "type": "integer", "minimum": 1024 },
        "max_budget_usd": { "type": "number", "exclusiveMinimum": 0 },
        "attempts": { "const": 1 }
      },
      "additionalProperties": false
    },
    "execution": {
      "type": "object",
      "required": [
        "cwd_strategy", "sanitized_argv", "started_at", "finished_at", "duration_ms", "exit_code"
      ],
      "properties": {
        "cwd_strategy": { "enum": ["source_read_only", "detached_worktree"] },
        "sanitized_argv": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "started_at": { "type": "string", "format": "date-time" },
        "finished_at": { "type": "string", "format": "date-time" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "exit_code": { "type": ["integer", "null"] }
      },
      "additionalProperties": false
    },
    "streams": {
      "type": "object",
      "required": ["stdout_sha256", "stderr_sha256", "stdout_truncated", "stderr_truncated"],
      "properties": {
        "stdout_sha256": { "$ref": "#/$defs/sha256" },
        "stderr_sha256": { "$ref": "#/$defs/sha256" },
        "stdout_truncated": { "type": "boolean" },
        "stderr_truncated": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "result": {
      "anyOf": [
        { "type": "object" },
        { "type": "null" }
      ]
    },
    "result_fingerprint": {
      "anyOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }]
    },
    "patch": {
      "anyOf": [
        {
          "type": "object",
          "required": ["path", "sha256", "changed_paths", "applied"],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "sha256": { "$ref": "#/$defs/sha256" },
            "changed_paths": {
              "type": "array",
              "uniqueItems": true,
              "items": { "type": "string", "minLength": 1 }
            },
            "applied": { "const": false }
          },
          "additionalProperties": false
        },
        { "type": "null" }
      ]
    },
    "status": { "enum": ["complete", "blocked", "failed", "forbidden"] },
    "issues": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "metadata": {
      "type": "object",
      "required": ["session_id", "cost_usd"],
      "properties": {
        "session_id": { "type": ["string", "null"] },
        "cost_usd": { "type": ["number", "null"], "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  },
  "additionalProperties": false
}

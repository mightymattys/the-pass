{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://the-pass.dev/schemas/instrument_registry.v2.schema.json",
  "title": "InstrumentRegistryV2",
  "type": "object",
  "required": ["schema_version", "registry_id", "created_at", "source", "instruments", "fingerprint"],
  "properties": {
    "schema_version": { "const": 2 },
    "registry_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "source": { "type": "string", "minLength": 1 },
    "instruments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["instrument_id", "symbol", "venue", "asset_class", "tick_size", "lot_size", "multiplier", "quote_currency", "contract_type"],
        "properties": {
          "instrument_id": { "type": "string", "minLength": 1 },
          "symbol": { "type": "string", "minLength": 1 },
          "venue": { "type": "string", "minLength": 1 },
          "asset_class": { "type": "string", "minLength": 1 },
          "tick_size": { "type": "string", "pattern": "^[0-9]+(?:\\.[0-9]+)?$" },
          "lot_size": { "type": "string", "pattern": "^[0-9]+(?:\\.[0-9]+)?$" },
          "multiplier": { "type": "string", "pattern": "^[0-9]+(?:\\.[0-9]+)?$" },
          "quote_currency": { "type": "string", "minLength": 1 },
          "contract_type": { "enum": ["spot", "future", "perpetual", "prediction_outcome", "synthetic"] },
          "expiry": { "type": ["string", "null"], "format": "date-time" },
          "margin_mode": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "fingerprint": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" }
  },
  "additionalProperties": false
}

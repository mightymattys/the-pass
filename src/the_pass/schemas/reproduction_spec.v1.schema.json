{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://the-pass.dev/schemas/reproduction_spec.v1.schema.json",
  "title": "ReproductionSpec",
  "type": "object",
  "required": ["schema_version", "id", "created_at", "runner_id", "network_allowed", "inputs", "input_fingerprints", "expected_artifacts"],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "runner_id": { "const": "the_pass.backtest.run.v1" },
    "network_allowed": { "const": false },
    "inputs": {
      "type": "object",
      "required": ["strategy_spec", "data_manifest", "quality_report", "descriptor", "execution", "events", "workspace"],
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "input_fingerprints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        },
        "additionalProperties": false
      }
    },
    "expected_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}

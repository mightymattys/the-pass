{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://the-pass.dev/schemas/audit_report.v2.schema.json",
  "title": "AuditReportV2",
  "type": "object",
  "required": ["schema_version", "id", "created_at", "target", "reviewer", "findings", "verdict", "evidence", "limitations"],
  "properties": {
    "schema_version": { "const": 2 },
    "id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "target": { "type": "string", "minLength": 1 },
    "reviewer": { "type": "string", "minLength": 1 },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "title", "evidence", "status", "recommendation", "promotion_impact", "blocks_promotion"],
        "properties": {
          "severity": { "enum": ["P0", "P1", "P2", "P3"] },
          "title": { "type": "string", "minLength": 1 },
          "evidence": { "type": "string", "minLength": 1 },
          "status": { "enum": ["open", "confirmed", "resolved", "accepted_risk"] },
          "recommendation": { "type": "string", "minLength": 1 },
          "promotion_impact": { "enum": ["none", "warning", "blocks_promotion"] },
          "blocks_promotion": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "verdict": { "enum": ["pass", "blocked", "revise", "kill"] },
    "evidence": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "limitations": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  },
  "additionalProperties": false
}

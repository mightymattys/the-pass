{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://the-pass.dev/schemas/agent_result.schema.json",
  "title": "AgentResultV1",
  "type": "object",
  "required": [
    "schema_version", "task_id", "status", "summary", "findings", "changed_paths",
    "next_actions", "assumptions", "issues"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "task_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$" },
    "status": { "type": "string", "enum": ["complete", "blocked", "failed"] },
    "summary": { "type": "string", "minLength": 1, "maxLength": 12000 },
    "findings": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "required": ["severity", "title", "evidence_paths", "recommendation"],
        "properties": {
          "severity": { "type": "string", "enum": ["P0", "P1", "P2", "P3", "info"] },
          "title": { "type": "string", "minLength": 1, "maxLength": 500 },
          "evidence_paths": {
            "type": "array",
            "maxItems": 100,
            "items": { "type": "string", "minLength": 1 }
          },
          "recommendation": { "type": "string", "minLength": 1, "maxLength": 4000 }
        },
        "additionalProperties": false
      }
    },
    "changed_paths": {
      "type": "array",
      "uniqueItems": true,
      "maxItems": 200,
      "items": { "type": "string", "minLength": 1 }
    },
    "next_actions": {
      "type": "array",
      "maxItems": 30,
      "items": { "type": "string", "minLength": 1, "maxLength": 1000 }
    },
    "assumptions": {
      "type": "array",
      "maxItems": 30,
      "items": { "type": "string", "minLength": 1, "maxLength": 1000 }
    },
    "issues": {
      "type": "array",
      "maxItems": 100,
      "items": { "type": "string", "minLength": 1, "maxLength": 2000 }
    }
  },
  "additionalProperties": false
}

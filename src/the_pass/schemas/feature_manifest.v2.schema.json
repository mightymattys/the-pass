{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://the-pass.dev/schemas/feature_manifest.v2.schema.json",
  "title": "FeatureManifestV2",
  "type": "object",
  "required": ["schema_version", "id", "created_at", "dataset_fingerprint", "code_version", "config_hash", "features", "rows", "output_fingerprint"],
  "properties": {
    "schema_version": { "const": 2 },
    "id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "dataset_fingerprint": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
    "code_version": { "type": "string", "minLength": 1 },
    "config_hash": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
    "features": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "rows": { "type": "integer", "minimum": 1 },
    "output_fingerprint": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://the-pass.dev/schemas/metrics_report.schema.json",
  "title": "MetricsReport",
  "type": "object",
  "required": ["schema_version", "id", "run_receipt", "created_at", "sample", "gross_metrics", "net_metrics", "robustness"],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "run_receipt": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "sample": {
      "type": "object",
      "required": ["start_time", "end_time", "evaluation_scope", "trades", "signals", "instruments"],
      "properties": {
        "start_time": { "type": "string", "minLength": 1 },
        "end_time": { "type": "string", "minLength": 1 },
        "evaluation_scope": { "enum": ["in_sample", "out_of_sample", "walk_forward", "diagnostic"] },
        "holdout_start_time": { "type": "string" },
        "holdout_end_time": { "type": "string" },
        "trades": { "type": "integer", "minimum": 0 },
        "signals": { "type": "integer", "minimum": 0 },
        "instruments": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "gross_metrics": {
      "type": "object",
      "required": ["pnl", "sharpe", "max_drawdown", "win_rate", "turnover"],
      "properties": {
        "pnl": { "type": ["number", "null"] },
        "sharpe": { "type": ["number", "null"] },
        "max_drawdown": { "type": ["number", "null"] },
        "win_rate": { "type": ["number", "null"] },
        "turnover": { "type": ["number", "null"] }
      }
    },
    "net_metrics": {
      "type": "object",
      "required": ["pnl", "sharpe", "max_drawdown", "win_rate", "turnover"],
      "properties": {
        "pnl": { "type": ["number", "null"] },
        "sharpe": { "type": ["number", "null"] },
        "max_drawdown": { "type": ["number", "null"] },
        "win_rate": { "type": ["number", "null"] },
        "turnover": { "type": ["number", "null"] }
      }
    },
    "robustness": {
      "type": "object",
      "required": ["null_baseline_result", "dsr_or_psr", "pbo", "stress_results", "parameter_stability"],
      "properties": {
        "null_baseline_result": { "type": "string" },
        "dsr_or_psr": { "type": ["number", "null"] },
        "pbo": { "type": ["number", "null"] },
        "stress_results": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "parameter_stability": { "type": "string" }
      }
    },
    "limitations": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}

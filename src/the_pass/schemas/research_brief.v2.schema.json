{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://the-pass.dev/schemas/research_brief.v2.schema.json",
  "title": "ResearchBriefV2",
  "type": "object",
  "required": ["schema_version", "id", "created_at", "topic", "owner", "objective", "sources", "hypotheses", "evidence_gaps", "next_tests", "status"],
  "properties": {
    "schema_version": { "const": 2 },
    "id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "topic": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "objective": { "type": "string", "minLength": 1 },
    "sources": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "hypotheses": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "evidence_gaps": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "next_tests": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "status": { "enum": ["draft", "ready", "blocked", "closed"] }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://the-pass.dev/schemas/agent_task.schema.json",
  "title": "AgentTaskV1",
  "type": "object",
  "required": [
    "schema_version", "task_id", "created_at", "caller_provider", "target_provider",
    "role", "objective", "acceptance_criteria", "workspace_root", "input_paths", "mode",
    "allowed_write_paths", "timeout_seconds", "max_output_bytes", "max_budget_usd",
    "allow_native_subagents", "forbidden_actions"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "task_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$" },
    "created_at": { "type": "string", "format": "date-time" },
    "caller_provider": { "enum": ["codex", "claude"] },
    "target_provider": { "enum": ["codex", "claude"] },
    "role": { "enum": ["researcher", "implementer", "reviewer"] },
    "objective": { "type": "string", "minLength": 1, "maxLength": 12000 },
    "acceptance_criteria": {
      "type": "array",
      "maxItems": 30,
      "items": { "type": "string", "minLength": 1, "maxLength": 1000 }
    },
    "workspace_root": { "type": "string", "minLength": 1 },
    "input_paths": {
      "type": "array",
      "maxItems": 100,
      "items": { "type": "string", "minLength": 1 }
    },
    "mode": { "enum": ["read_only", "worktree_patch"] },
    "allowed_write_paths": {
      "type": "array",
      "maxItems": 100,
      "items": { "type": "string", "minLength": 1 }
    },
    "timeout_seconds": { "type": "integer", "minimum": 1 },
    "max_output_bytes": { "type": "integer", "minimum": 1024 },
    "max_budget_usd": { "type": "number", "exclusiveMinimum": 0 },
    "allow_native_subagents": { "type": "boolean" },
    "forbidden_actions": {
      "type": "array",
      "minItems": 5,
      "uniqueItems": true,
      "items": {
        "enum": [
          "gate_decision", "live_transaction", "credential_access", "permission_bypass",
          "recursive_cross_provider", "apply_patch", "git_commit", "git_push"
        ]
      }
    }
  },
  "additionalProperties": false
}

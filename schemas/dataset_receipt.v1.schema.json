{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://the-pass.dev/schemas/dataset_receipt.v1.schema.json",
  "title": "DatasetReceipt",
  "type": "object",
  "required": ["schema_version", "id", "created_at", "plan_fingerprint", "dataset_fingerprint", "quality_fingerprint", "manifest_fingerprint", "event_count", "chunks", "cross_check_required", "cross_check_status", "promotion_impact", "commit_fingerprint"],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "plan_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "dataset_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "quality_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "manifest_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "event_count": { "type": "integer", "minimum": 1 },
    "chunks": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "cross_check_required": { "type": "boolean" },
    "cross_check_status": { "type": "string", "enum": ["pass", "incomplete"] },
    "promotion_impact": { "type": "string", "enum": ["none", "diagnostic_only", "blocked"] },
    "commit_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  },
  "additionalProperties": false
}

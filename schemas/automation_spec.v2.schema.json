{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://the-pass.dev/schemas/automation_spec.v2.schema.json",
  "title": "AutomationSpecV2",
  "type": "object",
  "required": ["schema_version", "id", "owner", "trigger", "command", "inputs", "allowed_writes", "forbidden_actions", "timeout_seconds", "retry_policy", "alert_sink", "freeze_procedure"],
  "properties": {
    "schema_version": { "const": 2 },
    "id": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "trigger": { "type": "object", "minProperties": 1 },
    "command": { "type": "string", "minLength": 1 },
    "inputs": { "type": "object" },
    "allowed_writes": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "forbidden_actions": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "timeout_seconds": { "type": "integer", "minimum": 1 },
    "retry_policy": {
      "type": "object",
      "required": ["max_attempts", "idempotent_only"],
      "properties": {
        "max_attempts": { "type": "integer", "minimum": 1 },
        "idempotent_only": { "const": true }
      },
      "additionalProperties": false
    },
    "alert_sink": { "type": "string", "minLength": 1 },
    "freeze_procedure": { "type": "string", "minLength": 1 },
    "enabled": { "type": "boolean" }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://the-pass.dev/schemas/risk_report.v2.schema.json",
  "title": "RiskReportV2",
  "type": "object",
  "required": ["schema_version", "id", "created_at", "package_id", "policy_id", "policy_hash", "sizing", "drawdown_distribution", "expected_shortfall", "risk_of_ruin_proxy", "worst_windows", "exposure_correlation", "scenario_losses", "capacity", "blockers", "verdict"],
  "properties": {
    "schema_version": { "const": 2 },
    "id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "package_id": { "type": "string", "minLength": 1 },
    "policy_id": { "type": "string", "minLength": 1 },
    "policy_hash": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
    "sizing": { "type": "object", "minProperties": 1 },
    "drawdown_distribution": { "type": "object", "minProperties": 1 },
    "expected_shortfall": { "type": "number", "minimum": 0 },
    "risk_of_ruin_proxy": { "type": "number", "minimum": 0, "maximum": 1 },
    "worst_windows": { "type": "array", "items": { "type": "object" } },
    "exposure_correlation": { "type": "object" },
    "scenario_losses": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "capacity": { "type": "object", "minProperties": 1 },
    "blockers": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "verdict": { "enum": ["pass", "blocked", "revise", "kill"] }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://the-pass.dev/schemas/reviewer_key_registry.v1.schema.json",
  "title": "ReviewerKeyRegistry",
  "type": "object",
  "required": ["schema_version", "id", "created_at", "keys"],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "keys": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["key_id", "reviewer", "principal_type", "provider", "public_key", "valid_from", "valid_until", "revoked_at"],
        "properties": {
          "key_id": { "type": "string", "pattern": "^key_[a-f0-9]{16}$" },
          "reviewer": { "type": "string", "minLength": 1 },
          "principal_type": { "enum": ["provider", "human"] },
          "provider": { "type": "string", "minLength": 1 },
          "public_key": { "type": "string", "pattern": "^[A-Za-z0-9+/]{43}=$" },
          "valid_from": { "type": "string", "format": "date-time" },
          "valid_until": { "type": "string", "format": "date-time" },
          "revoked_at": {
            "oneOf": [
              { "type": "null" },
              { "type": "string", "format": "date-time" }
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

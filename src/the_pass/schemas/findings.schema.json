{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://the-pass.dev/schemas/findings.schema.json",
  "title": "ReviewFindings",
  "type": "object",
  "required": ["schema_version", "id", "created_at", "package", "reviewer", "target_gate", "findings", "summary"],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "package": { "type": "string", "minLength": 1 },
    "reviewer": { "type": "string", "minLength": 1 },
    "target_gate": { "enum": ["research_gate", "paper_gate", "risk_review", "live_gate"] },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "status", "title", "evidence", "blocks_promotion", "recommendation"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "severity": { "enum": ["P0", "P1", "P2", "P3"] },
          "status": { "enum": ["open", "confirmed", "dismissed", "fixed"] },
          "title": { "type": "string", "minLength": 1 },
          "evidence": {
            "type": "object",
            "required": ["artifact", "path", "note"],
            "properties": {
              "artifact": { "type": "string", "minLength": 1 },
              "path": { "type": "string", "minLength": 1 },
              "note": { "type": "string", "minLength": 1 }
            }
          },
          "blocks_promotion": { "type": "boolean" },
          "recommendation": { "type": "string", "minLength": 1 }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["gate_result", "unresolved_blockers", "next_action"],
      "properties": {
        "gate_result": { "enum": ["pass", "blocked", "revise", "kill"] },
        "unresolved_blockers": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "next_action": { "type": "string", "minLength": 1 }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "summary": { "properties": { "gate_result": { "const": "pass" } } } } },
      "then": { "properties": { "summary": { "properties": { "unresolved_blockers": { "maxItems": 0 } } } } }
    }
  ],
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://the-pass.dev/schemas/dataset_plan.v1.schema.json",
  "title": "DatasetPlan",
  "type": "object",
  "required": ["schema_version", "id", "created_at", "provider", "kind", "instrument_id", "requested_interval", "chunk_ns", "expected_interval_ns", "cross_check_required", "requests", "plan_fingerprint"],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "provider": { "type": "string", "enum": ["binance", "polymarket", "futures"] },
    "kind": { "type": "string", "minLength": 1 },
    "instrument_id": { "type": "string", "minLength": 1 },
    "requested_interval": {
      "type": "object",
      "required": ["start_ns", "end_ns"],
      "properties": {
        "start_ns": { "type": "integer", "minimum": 0 },
        "end_ns": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "chunk_ns": { "type": "integer", "minimum": 1 },
    "expected_interval_ns": { "type": ["integer", "null"], "minimum": 1 },
    "cross_check_required": { "type": "boolean" },
    "requests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["chunk_id", "request", "request_fingerprint"],
        "properties": {
          "chunk_id": { "type": "string", "pattern": "^chunk-[0-9]{6}$" },
          "request": { "type": "object" },
          "request_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        },
        "additionalProperties": false
      }
    },
    "plan_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  },
  "additionalProperties": false
}

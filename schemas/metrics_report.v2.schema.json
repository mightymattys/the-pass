{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://the-pass.dev/schemas/metrics_report.v2.schema.json",
  "title": "MetricsReport",
  "type": "object",
  "required": ["schema_version", "id", "run_receipt", "created_at", "sample", "gross_metrics", "net_metrics", "not_applicable_reasons", "robustness"],
  "properties": {
    "schema_version": { "const": 2 },
    "id": { "type": "string", "minLength": 1 },
    "run_receipt": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "sample": {
      "type": "object",
      "required": ["start_time", "end_time", "evaluation_scope", "trades", "signals", "instruments"],
      "properties": {
        "start_time": { "type": "string", "minLength": 1 },
        "end_time": { "type": "string", "minLength": 1 },
        "evaluation_scope": { "enum": ["in_sample", "out_of_sample", "walk_forward", "diagnostic"] },
        "holdout_start_time": { "type": "string" },
        "holdout_end_time": { "type": "string" },
        "trades": { "type": "integer", "minimum": 0 },
        "signals": { "type": "integer", "minimum": 0 },
        "instruments": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "annualization": {
      "type": "object",
      "required": ["method", "calendar", "median_interval_seconds", "periods_per_year"],
      "properties": {
        "method": { "const": "asset_calendar_over_median_equity_interval" },
        "calendar": { "enum": ["continuous_365.25_days", "252_sessions_x_6.5_hours"] },
        "median_interval_seconds": { "type": "number", "exclusiveMinimum": 0 },
        "periods_per_year": { "type": "number", "exclusiveMinimum": 0 }
      },
      "additionalProperties": false
    },
    "gross_metrics": {
      "type": "object",
      "required": ["pnl", "total_return", "annualized_return", "volatility", "downside_volatility", "sharpe", "sortino", "calmar", "max_drawdown", "average_drawdown", "drawdown_duration", "win_rate", "payoff_ratio", "expectancy", "turnover", "average_holding_period", "expected_shortfall", "capacity_estimate"],
      "properties": {
        "pnl": { "type": ["number", "null"] },
        "total_return": { "type": ["number", "null"] },
        "annualized_return": { "type": ["number", "null"] },
        "volatility": { "type": ["number", "null"] },
        "downside_volatility": { "type": ["number", "null"] },
        "sharpe": { "type": ["number", "null"] },
        "sortino": { "type": ["number", "null"] },
        "calmar": { "type": ["number", "null"] },
        "max_drawdown": { "type": ["number", "null"] },
        "average_drawdown": { "type": ["number", "null"] },
        "drawdown_duration": { "type": ["number", "null"] },
        "win_rate": { "type": ["number", "null"] },
        "payoff_ratio": { "type": ["number", "null"] },
        "expectancy": { "type": ["number", "null"] },
        "turnover": { "type": ["number", "null"] },
        "average_holding_period": { "type": ["number", "null"] },
        "expected_shortfall": { "type": ["number", "null"] },
        "capacity_estimate": { "type": ["number", "null"] }
      }
    },
    "net_metrics": {
      "type": "object",
      "required": ["pnl", "total_return", "annualized_return", "volatility", "downside_volatility", "sharpe", "sortino", "calmar", "max_drawdown", "average_drawdown", "drawdown_duration", "win_rate", "payoff_ratio", "expectancy", "turnover", "average_holding_period", "expected_shortfall", "capacity_estimate"],
      "properties": {
        "pnl": { "type": ["number", "null"] },
        "total_return": { "type": ["number", "null"] },
        "annualized_return": { "type": ["number", "null"] },
        "volatility": { "type": ["number", "null"] },
        "downside_volatility": { "type": ["number", "null"] },
        "sharpe": { "type": ["number", "null"] },
        "sortino": { "type": ["number", "null"] },
        "calmar": { "type": ["number", "null"] },
        "max_drawdown": { "type": ["number", "null"] },
        "average_drawdown": { "type": ["number", "null"] },
        "drawdown_duration": { "type": ["number", "null"] },
        "win_rate": { "type": ["number", "null"] },
        "payoff_ratio": { "type": ["number", "null"] },
        "expectancy": { "type": ["number", "null"] },
        "turnover": { "type": ["number", "null"] },
        "average_holding_period": { "type": ["number", "null"] },
        "expected_shortfall": { "type": ["number", "null"] },
        "capacity_estimate": { "type": ["number", "null"] }
      }
    },
    "not_applicable_reasons": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "robustness": {
      "type": "object",
      "required": ["null_baseline_result", "dsr_or_psr", "pbo", "stress_results", "parameter_stability"],
      "properties": {
        "null_baseline_result": { "type": "string" },
        "dsr_or_psr": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "pbo": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "stress_results": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "parameter_stability": { "type": "string" }
      }
    },
    "limitations": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
